{
  "version": 2,
  "builds": [
    { "src": "api/tryon.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/tryon", "dest": "/api/tryon.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/tryon.js": {
      "maxDuration": 120
    }
  }
}
